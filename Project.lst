				; ---------------------------------------------------------------------------------
				; Name: ParseIntsFromString
				;
				; Parse through a string containing integer readings and converts the individual   
				;	integers from ASCII to numeric value, then stores them in an array. 
				;
				; Preconditions: 1st parameter must be a string of type BYTE and 2nd parameter is 
				;	an array of type SDWORD
				;
				; Receives:
				;	[EBP + 12]	= file buffer address
				;	[EBP + 8]	= integer array address
				;
				; Returns: 
				;	[EBP + 8]	= array of integers as numeric values
				; ---------------------------------------------------------------------------------
 000000A3			ParseIntsFromString PROC
					; Push Registers
 000000A3  55				PUSH	EBP
 000000A4  8B EC			MOV		EBP, ESP
 000000A6  57				PUSH	EDI
 000000A7  56				PUSH	ESI
 000000A8  51				PUSH	ECX
 000000A9  50				PUSH	EAX
 000000AA  53				PUSH	EBX
 000000AB  52				PUSH	EDX

					; Register Setup
 000000AC  8B 7D 08			MOV		EDI, [EBP + 8]
 000000AF  8B 75 0C			MOV		ESI, [EBP + 12]
 000000B2  B9 00000000			MOV		ECX, 0
 000000B7  BB 00000000			MOV		EBX, 0
 000000BC  BA 00000000			MOV		EDX, 0

					; Start of loop
 000000C1  FC				CLD
 000000C2			_Loop:
 000000C2  AC				LODSB

					; Check if character is a BACKSLASH
 000000C3  3C 0D			CMP		AL, CARRIAGE_RETURN	
 000000C5  75 09			JNE	   _Continue
 000000C7			_GetNextDay:
 000000C7  AC				LODSB
 000000C8  41				INC		ECX								; Increment pass \r\n in list
 000000C9  83 F9 02			CMP		ECX, 2
 000000CC  74 02			JE	   _Continue
 000000CE  EB F7			JMP	   _GetNextDay
 000000D0			_Continue:
 000000D0  B9 00000000			MOV		ECX, 0

					; Check if character is a Null-Terminate
 000000D5  3C 00			CMP		AL, 0
 000000D7  74 4B			JE	   _End

					; Check if character is a MINUS
 000000D9  3C 2D			CMP		AL, ASCII_MINUS
 000000DB  74 26			JE	   _NegativeIsTrue

					; Check if character is a COMMA
 000000DD  3C 2C			CMP		AL, ASCII_COMMA
 000000DF  74 29			JE	   _SaveToArray

					; Check if previous digit is zero (not ascii zero)
 000000E1  83 FA 00			CMP		EDX, 0
 000000E4  75 0D			JNE	   _ConcatenateDigit
 000000E6  2C 30			SUB		AL, ASCII_ZERO					; Convert character to number
 000000E8  66| 0F BE C0			MOVSX	AX, AL
 000000EC  0F BF C0			MOVSX	EAX, AX
 000000EF  03 D0			ADD		EDX, EAX						; Save number to EDX
 000000F1  EB CF			JMP	   _Loop

					; Concatenate Digits
 000000F3			_ConcatenateDigit:
 000000F3  2C 30			SUB		AL, ASCII_ZERO
 000000F5  66| 0F BE C0			MOVSX	AX, AL
 000000F9  0F BF C0			MOVSX	EAX, AX
 000000FC  6B D2 0A			IMUL	EDX, 10
 000000FF  03 D0			ADD		EDX, EAX
 00000101  EB BF			JMP	   _Loop

					; Remember Sign
 00000103			_NegativeIsTrue:
 00000103  BB 00000001			MOV		EBX, 1
 00000108  EB B8			JMP	   _Loop
					
					; Save to Array
 0000010A			_SaveToArray:
 0000010A  8B C2			MOV		EAX, EDX
 0000010C  83 FB 00			CMP		EBX, 0							; check if number is negative
 0000010F  74 02			JE	   _Save
 00000111  F7 D8			NEG		EAX								; make integer into negative integer
 00000113			_Save:
 00000113  89 07			MOV		[EDI], EAX
 00000115  83 C7 04			ADD		EDI, 4
 00000118  BB 00000000			MOV		EBX, 0
 0000011D  BA 00000000			MOV		EDX, 0
 00000122  EB 9E			JMP	   _Loop

					; Append SENTINEL_VALUE to array, 222 > 200(MAX_INT)
 00000124			_End:
 00000124  B9 00000018			MOV		ECX, INTS_PER_LINE
 00000129  BB 000000DE			MOV		EBX, SENTINEL_VALUE
 0000012E			_Fill:
 0000012E  89 1F			MOV		[EDI], EBX
 00000130  83 C7 04			ADD		EDI, 4
 00000133  E2 F9			LOOP   _Fill

					; Pop Registers
 00000135  5A				POP		EDX
 00000136  5B				POP		EBX
 00000137  58				POP		EAX
 00000138  59				POP		ECX
 00000139  5E				POP		ESI
 0000013A  5F				POP		EDI
 0000013B  5D				POP		EBP
 0000013C  C2 0008			RET		8
 0000013F			ParseIntsFromString ENDP

